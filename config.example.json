    "server_model": "Qwen3-8B-Q4_K_M",
    "context_window_tokens": 16384,
    "max_input_tokens": 12000,
    "max_new_tokens": 2048,
    "token_estimation_chars_per_token": 4.0,
    "json_retries": 1,
    "enable_thinking": false,
    "manage_server": true,
    "server_executable": "PATH/TO/llama-server",
    "server_model_path": "PATH/TO/model.gguf",
    "server_arguments": [
      "--no-webui",
      "--reasoning",
      "off",
      "-ngl",
      "999",
      "-c",
      "16384",
      "-np",
      "1"
    ],
    "server_log_dir": "output/diagnostics/llama_server",
    "server_startup_timeout_seconds": 180,
    "server_shutdown_timeout_seconds": 15,
    "server_auto_stop": true
  },
  "ai_final": {
    "backend": "llama_cpp_server",
    "base_url": "http://127.0.0.1:8080/v1",
    "server_model": "Qwen3-8B-Q4_K_M",
    "context_window_tokens": 16384,
    "max_input_tokens": 12000,
    "max_new_tokens": 2048,
    "token_estimation_chars_per_token": 4.0,
    "json_retries": 1,
    "enable_thinking": false,
    "manage_server": true,
    "server_executable": "PATH/TO/llama-server",
    "server_model_path": "PATH/TO/model.gguf",
    "server_arguments": [
      "--no-webui",
      "--reasoning",
      "off",
      "-ngl",
      "999",
      "-c",
      "16384",
      "-np",
      "1"
    ],
    "server_log_dir": "output/diagnostics/llama_server",
    "server_startup_timeout_seconds": 180,
    "server_shutdown_timeout_seconds": 15,
    "server_auto_stop": true
  },
  "general_topics": [
    {
      "name": "World and politics",
      "description": "Major international, geopolitical, diplomatic, legal, election, conflict, and public policy developments that a general reader should know.",
      "queries": [
        "top world news today",
        "major politics world news",
        "geopolitics diplomacy conflict latest"
      ],
      "enabled": true,
      "max_results": 16
    },
    {
      "name": "Business and economy",
      "description": "Major macroeconomic, market, central bank, trade, corporate, energy, and labor developments.",
      "queries": [
        "top business economy news today",
        "global economy markets central banks",
        "trade tariffs energy economy news"
      ],
      "enabled": true,
      "max_results": 14
    },
    {
      "name": "Technology and science",
      "description": "Major technology, AI, cybersecurity, space, health, science, and climate developments with broad impact.",
      "queries": [
        "top technology science news today",
        "AI cybersecurity science climate latest",
        "space health science breakthrough news"
      ],
      "enabled": true,
      "max_results": 14
    },
    {
      "name": "United States",
      "description": "Major US national stories, policy, courts, economy, public safety, and social developments.",
      "queries": [
        "top US news today",
        "US politics courts economy news",
        "major United States news latest"
      ],
      "enabled": true,
      "max_results": 12
    }
  ],
  "topics_to_examine": [
    {
      "name": "AI and technology policy",
      "description": "AI regulation, model governance, safety policy, semiconductor controls, platform accountability, and major AI industry moves with policy consequences.",
      "queries": [
        "AI regulation policy",
        "artificial intelligence safety governance",
        "AI chips export controls"
      ],
      "enabled": true,
      "max_results": 14,
      "max_selected_articles": 3
    },
    {
      "name": "Global economy",
      "description": "Major macroeconomic developments, central banks, inflation, trade, sovereign risk, China economy, energy, and market-moving policy shifts.",
      "queries": [
        "global economy inflation central banks",
        "China economy property trade",
        "global trade tariffs economy"
      ],
      "enabled": true,
      "max_results": 14,
      "max_selected_articles": 3
    },
    {
      "name": "Major world events",
      "description": "High-impact geopolitical, conflict, diplomatic, public health, climate, science, and disaster stories that deserve deeper narrative tracking.",
      "queries": [
        "major world news today",
        "geopolitics diplomacy conflict latest",
        "major science climate world news"
      ],
      "enabled": true,
      "max_results": 12,
      "max_selected_articles": 2
    }
  ],
  "user_memory": {
    "role": "Reader who wants practical daily context",
    "geography_focus": [
      "United States",
      "European Union",
      "China"
    ],
    "time_horizon": "tactical",
    "beats": {
      "AI and technology policy": 1.0,
      "Global macro and markets": 0.75,
      "Science and public health": 0.5
    },
    "wants": [
      "policy change",
      "regulatory enforcement",
      "market-moving guidance",
      "major scientific development"
    ],
    "avoid": [
      "celebrity news",
      "sports scores",
      "routine announcements"
    ],
    "portfolio_or_stake_notes": "Adjust this to the reader's work, investments, responsibilities, or recurring decisions.",
    "preferred_depth": "analytical",
    "avoided_topics": [
      "celebrity gossip",
      "minor sports updates"
    ],
    "preferred_sources": [
      "BBC World",
      "NPR",
      "Ars Technica"
    ],
    "avoided_sources": [],
    "briefing_style": "Concise, explanatory, practical, and skeptical of hype.",
    "custom_instructions": "Prefer narrative shifts and important developments over routine announcements. Include uncertainty when the available sources are thin."
  },
  "general_filtering": {
    "time_window_hours": 36,
    "headline_score_cutoff": 7.0,
    "max_headlines_per_source": 16,
    "max_candidates_for_ai": 60,
    "max_headlines_per_ai_batch": 12,
    "headline_max_input_tokens": 10000,
    "headline_max_new_tokens": 1600,
    "headline_single_replay_max_new_tokens": 768,
    "max_selected_articles": 12,
    "fill_selected_articles": true,
    "article_text_max_chars": 4500
  },
  "filtering": {
    "time_window_hours": 36,
    "headline_score_cutoff": 7.0,
    "max_headlines_per_source": 16,
    "max_candidates_for_ai": 48,
    "max_headlines_per_ai_batch": 10,
    "headline_max_input_tokens": 10000,
    "headline_max_new_tokens": 1600,
    "headline_single_replay_max_new_tokens": 768,
    "max_selected_articles": 8,
    "fill_selected_articles": false,
    "article_text_max_chars": 5000
  },
  "enrichment": {
    "enabled": true,
    "mode": "story_llm",
    "max_story_threads": 10,
    "planner_max_questions_per_story": 4,
    "search_results_per_query": 16,
    "max_fetched_research_pages_per_story": 8,
    "max_selected_article_excerpt_chars": 3600,
    "max_research_excerpt_chars": 2800,
    "cache_ttl_seconds": 604800,
    "max_context_chars_per_article": 3200
  },
  "pipeline": {
    "default_series": [
      "briefs",
      "enrichment",
      "narrative_brief"
    ]
  },
  "runtime": {
    "max_http_workers": 1,
    "max_article_workers": 1,
    "use_shared_snapshot": true
  },
  "narrative_briefing": {
    "enabled": true,
    "max_input_tokens": null,
    "max_new_tokens": null,
    "target_words": 1800,
    "editorial_style": "Write like a sharp human news editor, not a consultant memo. Use clear narrative paragraphs, concrete verbs, and varied sentence rhythm. Avoid repeated Status/Impact/Operational Implication labels. Do not address the reader as an operator. Use bullets sparingly, only for genuinely scannable watch items. Prefer 'what changed, why it matters, what remains uncertain' woven into prose."
  },
  "analysis": {
    "rollout": {
      "enabled": true,
      "profile": "balanced_local",
      "general": {
        "evidence_enabled": true,
        "delta_enabled": false,
        "evidence_max_input_tokens": 8000,
        "evidence_max_new_tokens": 1000,
        "evidence_max_articles": 8,
        "evidence_max_articles_per_batch": 4,
        "evidence_max_article_chars": 1200
      },
      "detailed": {
        "evidence_enabled": true,
        "delta_enabled": true,
        "evidence_max_input_tokens": 10000,
        "evidence_max_new_tokens": 1200,
        "evidence_max_articles": 10,
        "evidence_max_articles_per_batch": 5,
        "evidence_max_articles_dropped_to_avoid_split": 2,
        "evidence_max_article_chars": 1400,
        "delta_max_input_tokens": 8000,
        "delta_max_new_tokens": 1000,
        "delta_max_articles": 8,
        "delta_max_articles_per_batch": 4,
        "delta_max_articles_dropped_to_avoid_split": 2,
        "delta_max_article_chars": 600,
        "delta_max_prior_reports": 4
      }
    },
    "evidence_distillation": {
      "enabled": false,
      "model_role": "summary",
      "include_reader_qa": true,
      "max_input_tokens": 10000,
      "max_new_tokens": 1200,
      "max_articles": 10,
      "max_articles_per_batch": 5,
      "max_articles_dropped_to_avoid_split": 2,
      "max_article_chars": 1400,
      "max_context_sources_per_article": 3,
      "max_story_clusters": 8,
      "max_claims_per_cluster": 5,
      "max_questions": 8,
      "cache_ttl_seconds": 604800
    },
    "delta_extraction": {
      "enabled": false,
      "model_role": "summary",
      "input_source": "evidence_or_articles",
      "require_prior_reports": false,
      "max_input_tokens": 8000,
      "max_new_tokens": 1000,
      "max_articles": 8,
      "max_articles_per_batch": 4,
      "max_articles_dropped_to_avoid_split": 2,
      "max_article_chars": 600,
      "max_prior_reports": 4,
      "cache_ttl_seconds": 604800
    }
  },
  "cache": {
    "enabled": true,
    "dir": ".cache/mydailynews",
    "discovery_mode": "network_first",
    "article_text_retention_days": 3,
    "enrichment_retention_days": 30,
    "http_retention_days": 7,
    "ai_enabled": true,
    "synth_fresh_seconds": 604800
  },
  "sources": {
